{
	"name": "portfolio_site",
	"version": "0.1.0",
	"private": true,
	"engines": {
		"node": ">=24.18.0 <25",
		"npm": ">=11.17.0 <12"
	},
	"packageManager": "npm@11.17.0",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"preview": "serve out",
		"typecheck": "tsc --noEmit",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "npm run lint -- --fix",
		"lint:style": "stylelint 'src/**/*.{css,ts,tsx}'",
		"lint:style:fix": "npm run lint:style -- --fix",
		"format": "prettier --write . --ignore-path .gitignore",
		"format:check": "prettier --check . --ignore-path .gitignore",
		"check": "npm run typecheck && npm run lint && npm run lint:style && npm run format:check"
	},
	"dependencies": {
		"exifr": "^7.1.3",
		"next": "^16.2.10",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"styled-components": "^6.4.3"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"eslint": "^9.39.5",
		"eslint-config-next": "^16.2.10",
		"postcss-styled-syntax": "^0.7.2",
		"prettier": "^3.9.5",
		"serve": "^14.2.6",
		"stylelint": "^17.14.0",
		"stylelint-config-recess-order": "^7.7.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-order": "^8.1.1",
		"typescript": "^5.9.3"
	},
	"overrides": {
		"postcss": "^8.5.16"
	}
}
